<Window x:Class="DelegateTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delegate Tester - Points 1 to 5" Height="750" Width="450" MinHeight="700" MinWidth="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Points 1 & 2 Rows -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

            <!-- Point 3 Separator & Elements -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

            <!-- Point 4 Separator & Elements -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

            <!-- Point 5 Separator -->
            <RowDefinition Height="Auto"/>

            <!-- Point 5 Custom Sorting Elements -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Point 1 & 2: Single Input -->
        <Label Content="Enter a Real Number:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="InputTextBox" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />

        <GroupBox Header="Select an Operation" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="SquareRadio" Content="Square" Margin="0,0,20,0" Checked="Operation_Checked"/>
                <RadioButton x:Name="SquareRootRadio" Content="Square Root" Margin="0,0,20,0" Checked="Operation_Checked"/>
                <RadioButton x:Name="ReciprocalRadio" Content="Reciprocal" Checked="Operation_Checked"/>
            </StackPanel>
        </GroupBox>

        <Button x:Name="ExecuteButton" Content="Execute Single Method" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                Margin="0,15,0,0" Padding="10,5" Width="200" Click="ExecuteButton_Click"/>

        <TextBlock x:Name="ResultTextBlock" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                   Margin="0,15,0,0" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DarkBlue" />

        <!-- === POINT 3 ADDITIONS === -->
        <Separator Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,15" />

        <Label Content="Enter numbers (comma-separated):" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="InputListTextBox" Grid.Row="5" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />

        <Button x:Name="ProcessListButton" Content="Process Collection" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                Margin="0,15,0,0" Padding="10,5" Width="200" Click="ProcessListButton_Click"/>

        <TextBlock x:Name="ListResultTextBlock" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" 
                   Margin="0,15,0,0" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DarkGreen" TextWrapping="Wrap"/>

        <!-- === POINT 4 ADDITIONS === -->
        <Separator Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,15" />

        <Label x:Name="MulticastTargetLabel" Content="Watch my style change!" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" 
               HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="ApplyStylesButton" Content="Apply Multicast Styles" Padding="10,5" Width="150" Margin="0,0,15,0" Click="ApplyStylesButton_Click"/>
            <Button x:Name="ResetStylesButton" Content="Reset Appearance" Padding="10,5" Width="150" Click="ResetStylesButton_Click"/>
        </StackPanel>

        <!-- === POINT 5 ADDITIONS === -->
        <Separator Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,15" />

        <Label Content="Sort Numbers (comma-separated):" Grid.Row="12" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="SortInputTextBox" Grid.Row="12" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />

        <GroupBox Header="Select Sort Order" Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="AscendingRadio" Content="Ascending" Margin="0,0,20,0" IsChecked="True"/>
                <RadioButton x:Name="DescendingRadio" Content="Descending" />
            </StackPanel>
        </GroupBox>

        <Button x:Name="SortButton" Content="Sort Collection" Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" 
                Margin="0,15,0,0" Padding="10,5" Width="200" Click="SortButton_Click"/>

        <TextBlock x:Name="SortResultTextBlock" Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2" 
                   Margin="0,15,0,0" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DarkMagenta" TextWrapping="Wrap"/>

    </Grid>
</Window>