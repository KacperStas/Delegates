<Window x:Class="DelegateTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delegate Tester - Point 1" Height="250" Width="450" MinHeight="200" MinWidth="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Input Field -->
        <Label Content="Enter a Real Number:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <TextBox x:Name="InputTextBox" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />

        <!-- Operation Selection -->
        <GroupBox Header="Select an Operation" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <RadioButton x:Name="SquareRadio" Content="Square" Margin="0,0,20,0" Checked="Operation_Checked"/>
                <RadioButton x:Name="SquareRootRadio" Content="Square Root" Margin="0,0,20,0" Checked="Operation_Checked"/>
                <RadioButton x:Name="ReciprocalRadio" Content="Reciprocal" Checked="Operation_Checked"/>
            </StackPanel>
        </GroupBox>

    </Grid>
</Window>