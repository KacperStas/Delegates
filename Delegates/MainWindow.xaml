<Window x:Class="DelegateTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delegate Tester - All Points (1-6)" Height="850" Width="500" MinHeight="700" MinWidth="450">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <!-- Points 1 & 2 -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <!-- Point 3 -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <!-- Point 4 -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <!-- Points 5 & 6 Refactored -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <!-- Fills remaining space -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- === POINTS 1 & 2 === -->
            <Label Content="Enter a Real Number:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="InputTextBox" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />

            <GroupBox Header="Select an Operation" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0" Padding="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <RadioButton x:Name="SquareRadio" Content="Square" Margin="0,0,20,0" Checked="Operation_Checked"/>
                    <RadioButton x:Name="SquareRootRadio" Content="Square Root" Margin="0,0,20,0" Checked="Operation_Checked"/>
                    <RadioButton x:Name="ReciprocalRadio" Content="Reciprocal" Checked="Operation_Checked"/>
                </StackPanel>
            </GroupBox>

            <Button x:Name="ExecuteButton" Content="Execute Single Method" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                    Margin="0,10,0,0" Padding="10,5" Width="200" Click="ExecuteButton_Click"/>

            <TextBlock x:Name="ResultTextBlock" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                       Margin="0,10,0,0" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DarkBlue" />

            <!-- === POINT 3 === -->
            <Separator Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,10" />

            <Label Content="Enter numbers (comma-separated):" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="InputListTextBox" Grid.Row="5" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />

            <Button x:Name="ProcessListButton" Content="Process Collection" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                    Margin="0,10,0,0" Padding="10,5" Width="200" Click="ProcessListButton_Click"/>

            <TextBlock x:Name="ListResultTextBlock" Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" 
                       Margin="0,10,0,0" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="DarkGreen" TextWrapping="Wrap"/>

            <!-- === POINT 4 === -->
            <Separator Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,15,0,10" />

            <Label x:Name="MulticastTargetLabel" Content="Watch my style change!" Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ApplyStylesButton" Content="Apply Multicast Styles" Padding="10,5" Width="150" Margin="0,0,15,0" Click="ApplyStylesButton_Click"/>
                <Button x:Name="ResetStylesButton" Content="Reset Appearance" Padding="10,5" Width="150" Click="ResetStylesButton_Click"/>
            </StackPanel>

            <!-- === POINTS 5 & 6 (Generics) === -->
            <Separator Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,10" />

            <TextBlock Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Text="Points 5 &amp; 6: Generic Sorting" 
                       FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- GroupBox for Numbers (Consolidates rows) -->
            <GroupBox Header="Number Sorting" Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Numbers (comma-separated):" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox x:Name="SortInputTextBox" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <RadioButton x:Name="AscendingRadio" Content="Ascending" Margin="0,0,15,0" IsChecked="True" VerticalAlignment="Center"/>
                        <RadioButton x:Name="DescendingRadio" Content="Descending" Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <Button Content="Sort Numbers" Padding="15,4" Click="SortNumbersButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="SortResultTextBlock" Margin="0,10,0,0" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Purple" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <!-- GroupBox for Strings (Consolidates rows) -->
            <GroupBox Header="String Sorting" Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" Padding="10">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Strings (comma-separated):" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBox x:Name="StringSortInputTextBox" Grid.Column="1" Margin="10,0,0,0" Padding="5" VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <RadioButton x:Name="StringAscendingRadio" Content="Ascending" Margin="0,0,15,0" IsChecked="True" VerticalAlignment="Center"/>
                        <RadioButton x:Name="StringDescendingRadio" Content="Descending" Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <Button Content="Sort Strings" Padding="15,4" Click="SortStringsButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="StringSortResultTextBlock" Margin="0,10,0,0" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Purple" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

        </Grid>
    </ScrollViewer>
</Window>